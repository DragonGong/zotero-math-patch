<?xml version="1.0"?>
<RDF:RDF
    xmlns:em="http://www.mozilla.org/2004/em-rdf#"
    xmlns:RDF="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <RDF:Description
      RDF:about="urn:mozilla:install-manifest"
      em:id="zotero-math-patch@local"
      em:name="Zotero Math Patch"
      em:version="0.2.4"
      em:type="2"
      em:creator="DragonGong"
      em:description="Repairs pasted math in Zotero notes with local rules or a user-configured AI service."
      em:updateURL="https://raw.githubusercontent.com/DragonGong/zotero-math-patch/main/updates.json"
      em:multiprocessCompatible="true"
      em:bootstrap="true">
    <em:targetApplication>
      <Description>
        <em:id>zotero@zotero.org</em:id>
        <em:minVersion>7.0.0</em:minVersion>
        <em:maxVersion>9.0.*</em:maxVersion>
      </Description>
    </em:targetApplication>
    <em:targetApplication>
      <Description>
        <em:id>zotero@chnm.gmu.edu</em:id>
        <em:minVersion>6.999</em:minVersion>
        <em:maxVersion>9.0.*</em:maxVersion>
      </Description>
    </em:targetApplication>
  </RDF:Description>
</RDF:RDF>
