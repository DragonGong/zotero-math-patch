<?xml version="1.0"?>
<RDF:RDF
    xmlns:em="http://www.mozilla.org/2004/em-rdf#"
    xmlns:RDF="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <RDF:Description
      RDF:about="urn:mozilla:install-manifest"
      em:id="zotero-math-patch@local"
      em:name="Zotero Markdown Math Patch"
      em:version="0.1.9"
      em:type="2"
      em:creator="Local"
      em:description="Manually renders pasted Markdown math in Zotero notes."
      em:updateURL="https://example.com/zotero-math-patch/updates.json"
      em:multiprocessCompatible="true"
      em:bootstrap="true">
    <em:targetApplication>
      <Description>
        <em:id>zotero@zotero.org</em:id>
        <em:minVersion>7.0.0</em:minVersion>
        <em:maxVersion>10.99.99</em:maxVersion>
      </Description>
    </em:targetApplication>
    <em:targetApplication>
      <Description>
        <em:id>zotero@chnm.gmu.edu</em:id>
        <em:minVersion>6.999</em:minVersion>
        <em:maxVersion>10.99.99</em:maxVersion>
      </Description>
    </em:targetApplication>
  </RDF:Description>
</RDF:RDF>
